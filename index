<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aplikasi Manajemen Haji</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Font Awesome untuk Icon -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- SweetAlert2 untuk Notifikasi & Loading -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  
  <!-- React & ReactDOM -->
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  
  <!-- Babel -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <style>
    /* Styling khusus animasi dan print */
    @media print {
      @page { margin: 1cm; }
      body * { visibility: hidden; }
      .print-area, .print-area * { visibility: visible; }
      .print-area { position: absolute; left: 0; top: 0; width: 100%; }
      .no-print { display: none !important; }
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes marquee {
      0% { transform: translateX(100%); }
      100% { transform: translateX(-100%); }
    }
    .fade-in-up { animation: fadeInUp 0.5s ease-out forwards; }
    .marquee { white-space: nowrap; display: inline-block; animation: marquee 18s linear infinite; }
    
    /* Scrollbar minimalis */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
  </style>
</head>
<body class="bg-gray-50 text-gray-800">

<div id="root"></div>

<script type="text/babel">
const { useState, useEffect } = React;

// --- MOCK DATA ---
const initialJamaah = [
  { id: 'HJ-001', paspor: 'X7834142', nama: 'HALIPAH HUSEN TALIP', gender: 'Perempuan', umur: 85, asal: 'KAB. MEMPAWAH', status: 'SEHAT' },
  { id: 'HJ-002', paspor: 'X6999935', nama: 'ASIRI DUL HABI', gender: 'Perempuan', umur: 85, asal: 'KAB. KAYONG UTARA', status: 'SEHAT' },
  { id: 'HJ-005', paspor: 'E8447264', nama: 'USMAN IBRAHIM', gender: 'Laki-laki', umur: 80, asal: 'KAB. MELAWI', status: 'SEHAT' },
  { id: 'HJ-007', paspor: 'X3585920', nama: 'MADENAN MAT ERAT', gender: 'Laki-laki', umur: 79, asal: 'KAB. SINTANG', status: 'SEHAT' },
  { id: 'HJ-018', paspor: 'E8440228', nama: 'MUMAMMAD YASIN', gender: 'Laki-laki', umur: 72, asal: 'KAB. SINTANG', status: 'SAKIT', diagnosa: 'ISPA', lokasiRawat: 'MAKKAH' },
];

const lokasiAsalList = [
  "KAB. MEMPAWAH", "KAB. KAYONG UTARA", "KAB. MELAWI", "KAB. KAPUAS HULU", 
  "KAB. SINTANG", "KAB. KETAPANG", "KAB. SEKADAU", "KAB. SAMBAS", 
  "KAB. BENGKAYANG", "KAB. LANDAK", "KAB. SANGGAU", "KAB. KUBU RAYA", 
  "KOTA PONTIANAK", "KOTA SINGKAWANG"
];

const initialPjList = [
  { id: 'PJ-001', nama: 'WILDA', noHp: '85821897002' },
  { id: 'PJ-002', nama: 'ADMIN PUSAT', noHp: '08123456789' }
];

function App() {
  const todayStr = new Date().toISOString().split('T')[0];
  // --- STATE MANAGEMENT ---
  const [isLoggedIn, setIsLoggedIn] = useState(false);
  const [currentUser, setCurrentUser] = useState({ role: 'admin', fullName: 'Administrator' });
  const [activeTab, setActiveTab] = useState('dashboard');
  const [jamaahData, setJamaahData] = useState([]);
  const [presensiData, setPresensiData] = useState([]);
  const [pjList, setPjList] = useState(initialPjList);
  const [isLoading, setIsLoading] = useState(false);
  const [printMode, setPrintMode] = useState('laporan'); // 'laporan' atau 'presensi'
  const [appConfig, setAppConfig] = useState({
    appName: 'SIHAJI PRO',
    headerLogo: '',
    loginLogo: '',
    signatoryName: '........................',
    fullName: 'Administrator',
    username: 'admin',
    password: 'admin123',
    adminPhoto: ''
  });
  const [dashboardDate, setDashboardDate] = useState(todayStr);
  const [showLoginForm, setShowLoginForm] = useState(false);
  const [loginPreviewDate, setLoginPreviewDate] = useState(todayStr);
  const [loginPreviewKab, setLoginPreviewKab] = useState('SEMUA');
  
  // Login State
  const [username, setUsername] = useState('');
  const [password, setPassword] = useState('');
  const [showPassword, setShowPassword] = useState(false);

  // UI State Jemaah
  const [searchTerm, setSearchTerm] = useState('');
  const [selectedIds, setSelectedIds] = useState([]);
  const [showBulkModal, setShowBulkModal] = useState(false);
  const [bulkStatus, setBulkStatus] = useState('SEHAT');
  const [bulkDetails, setBulkDetails] = useState({ diagnosa: '', lokasi: '', linkSertifikat: '', certificateFile: null });
  const [selectedKabupaten, setSelectedKabupaten] = useState('SEMUA');
  const [selectedJamaah, setSelectedJamaah] = useState(null);
  const [isEditingJamaah, setIsEditingJamaah] = useState(false);
  const [editJamaahDraft, setEditJamaahDraft] = useState(null);

  // Add Jamaah State
  const [showAddModal, setShowAddModal] = useState(false);
  const [newJamaah, setNewJamaah] = useState({ id: '', paspor: '', nama: '', gender: 'Laki-laki', umur: '', asal: lokasiAsalList[0], status: 'SEHAT' });

  // State Presensi
  const [tglKegiatan, setTglKegiatan] = useState(new Date().toISOString().split('T')[0]);
  const [namaKegiatan, setNamaKegiatan] = useState('');
  const [presensiSelected, setPresensiSelected] = useState([]);
  const [hidePresensiForm, setHidePresensiForm] = useState(false);
  const [presensiFilterTanggal, setPresensiFilterTanggal] = useState(todayStr);
  const [presensiSearchNama, setPresensiSearchNama] = useState('');
  
  // PJ Modal State
  const [showPjModal, setShowPjModal] = useState(false);
  const [selectedPjId, setSelectedPjId] = useState('');
  const [isNewPj, setIsNewPj] = useState(false);
  const [newPjName, setNewPjName] = useState('');
  const [newPjHp, setNewPjHp] = useState('');

  // --- HELPER: SWEETALERT ---
  const showLoadingAlert = (text = 'Memproses data...') => {
    Swal.fire({
      title: text,
      background: '#111827',
      color: '#fff',
      allowOutsideClick: false,
      showConfirmButton: false,
      didOpen: () => { Swal.showLoading(); }
    });
  };

  const modernAlert = (icon, title, text = '') => Swal.fire({
    icon,
    title,
    text,
    background: '#ffffff',
    showClass: { popup: 'animate__animated animate__zoomIn' },
    hideClass: { popup: 'animate__animated animate__fadeOut' }
  });

  const fileToBase64 = (file) => new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result.split(',')[1]);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });

  // --- INITIAL LOAD DATA ---
  useEffect(() => {
    if (typeof google !== 'undefined' && google.script) {
      showLoadingAlert('Memuat Data Utama...');
      google.script.run
        .withSuccessHandler((res) => {
          const serverData = Array.isArray(res?.data) ? res.data : [];
          if (serverData.length > 0) {
            setJamaahData(serverData);
            setPresensiSelected(serverData.map(j => j.id));
          } else {
            setJamaahData([]);
            setPresensiSelected([]);
            Swal.fire('Data kosong', res?.message || 'Data jemaah tidak ditemukan dari server.', 'warning');
          }
          Swal.close();
        })
        .withFailureHandler((err) => {
          console.error(err);
          setJamaahData([]);
          setPresensiSelected([]);
          Swal.fire('Error', 'Gagal memuat data Jemaah dari server', 'error');
        })
        .getJamaahDataServer();
        
      // Fetch PJ Data
      google.script.run
        .withSuccessHandler((res) => {
          if (res?.success && Array.isArray(res.data) && res.data.length > 0) setPjList(res.data);
        })
        .getPjDataServer();

      google.script.run
        .withSuccessHandler((res) => {
          if (res?.success && Array.isArray(res.data)) setPresensiData(res.data);
        })
        .getPresensiDataServer();
    } else {
      setJamaahData(initialJamaah);
      setPresensiSelected(initialJamaah.map(j => j.id));
    }
  }, []);

  useEffect(() => {
    const raw = localStorage.getItem('sihaji_config');
    if (raw) {
      try { setAppConfig(JSON.parse(raw)); } catch (e) {}
    }
    if (typeof google !== 'undefined' && google.script) {
      google.script.run
        .withSuccessHandler((res) => {
          if (res?.success && res.data) {
            setAppConfig(prev => ({ ...prev, ...res.data }));
          }
        })
        .getAppSettingsServer();
    }
  }, []);

  useEffect(() => {
    if (currentUser.role === 'viewer' && activeTab !== 'dashboard') setActiveTab('dashboard');
  }, [currentUser, activeTab]);

  // --- LOGIN LOGIC ---
  const handleLogin = (e) => {
    e.preventDefault();
    if (!username || !password) return;

    if (typeof google !== 'undefined' && google.script) {
      showLoadingAlert('Otentikasi...');
      setIsLoading(true);
      google.script.run
        .withSuccessHandler((res) => {
          setIsLoading(false);
          if (res?.success) {
            Swal.fire({ icon: 'success', title: 'Login Berhasil', timer: 1500, showConfirmButton: false });
            setCurrentUser({ role: res.role || 'admin', fullName: res.fullName || appConfig.fullName || 'Administrator' });
            setIsLoggedIn(true);
          } else {
            Swal.fire('Akses Ditolak', res?.message || 'Respons server kosong / tidak valid.', 'error');
          }
        })
        .verifyLoginServer(username, password);
    } else {
      if (username === (appConfig.username || 'admin') && password === (appConfig.password || 'admin123')) {
        Swal.fire({ icon: 'success', title: 'Login Berhasil', timer: 1500, showConfirmButton: false });
        setCurrentUser({ role: 'admin', fullName: appConfig.fullName || 'Administrator' });
        setIsLoggedIn(true);
      } else if (username === 'viewer' && password === 'viewer123') {
        setCurrentUser({ role: 'viewer', fullName: 'Viewer Dashboard' });
        setIsLoggedIn(true);
      } else {
        Swal.fire('Akses Ditolak', 'Username atau password salah! (Hint: admin / admin123)', 'error');
      }
    }
  };

  // --- ADD JAMAAH LOGIC ---
  const handleAddJamaah = (e) => {
    e.preventDefault();
    if (!newJamaah.id || !newJamaah.nama) return Swal.fire('Peringatan', 'ID dan Nama Wajib diisi!', 'warning');
    
    showLoadingAlert('Menyimpan Data...');
    setTimeout(() => {
      setJamaahData([...jamaahData, newJamaah]);
      setPresensiSelected([...presensiSelected, newJamaah.id]);
      setShowAddModal(false);
      setNewJamaah({ id: '', paspor: '', nama: '', gender: 'Laki-laki', umur: '', asal: lokasiAsalList[0], status: 'SEHAT' });
      Swal.fire('Tersimpan!', 'Data jemaah berhasil ditambahkan.', 'success');
    }, 500); // Simulasi loading untuk demo lokal
  };

  // --- BULK UPDATE STATUS JEMAAH ---
  const handleBulkUpdate = async () => {
    if (bulkStatus === 'MENINGGAL' && bulkDetails.certificateFile && typeof google !== 'undefined' && google.script) {
      showLoadingAlert('Upload sertifikat kematian...');
      try {
        const base64Data = await fileToBase64(bulkDetails.certificateFile);
        google.script.run
          .withSuccessHandler((res) => {
            if (res?.success) {
              setBulkDetails(prev => ({ ...prev, linkSertifikat: res.url }));
              executeBulkUpdate(res.url);
            } else {
              Swal.fire('Gagal upload', res?.message || 'Respons server kosong / tidak valid.', 'error');
            }
          })
          .withFailureHandler((err) => Swal.fire('Error', err.toString(), 'error'))
          .uploadCertificateServer({
            fileName: bulkDetails.certificateFile.name,
            mimeType: bulkDetails.certificateFile.type,
            base64Data
          });
        return;
      } catch (error) {
        Swal.fire('Error', 'Gagal membaca file sertifikat.', 'error');
        return;
      }
    }

    if (bulkStatus === 'MENINGGAL' && !bulkDetails.linkSertifikat) {
      // Optional: Peringatan jika link sertifikat kosong tapi tidak memblokir simpan
      Swal.fire({
        title: 'Peringatan',
        text: "Anda belum memasukkan Link Sertifikat Kematian. Yakin ingin melanjutkan?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Ya, Lanjutkan'
      }).then((result) => {
        if (result.isConfirmed) executeBulkUpdate();
      });
    } else {
      executeBulkUpdate();
    }
  };

  const executeBulkUpdate = (overrideLink = '') => {
    const finalLink = overrideLink || bulkDetails.linkSertifikat || '';
    const updatedItems = [];
    const updatedData = jamaahData.map(j => {
      if (selectedIds.includes(j.id)) {
        const history = Array.isArray(j.statusHistory) ? j.statusHistory : [];
        const updatedItem = { 
          ...j, 
          status: bulkStatus,
          diagnosa: bulkStatus === 'SAKIT' ? bulkDetails.diagnosa : '',
          lokasiRawat: bulkStatus === 'SAKIT' ? bulkDetails.lokasi : '',
          lokasiPemakaman: bulkStatus === 'MENINGGAL' ? bulkDetails.lokasi : '',
          linkSertifikat: bulkStatus === 'MENINGGAL' ? finalLink : '',
          updatedAt: new Date().toISOString(),
          statusHistory: [...history, {
            status: bulkStatus,
            catatan: bulkStatus === 'SAKIT' ? bulkDetails.diagnosa : bulkDetails.lokasi,
            waktu: new Date().toISOString(),
            linkSertifikat: bulkStatus === 'MENINGGAL' ? finalLink : ''
          }]
        };
        updatedItems.push(updatedItem);
        return updatedItem;
      }
      return j;
    });

    if (typeof google !== 'undefined' && google.script) {
       showLoadingAlert('Memperbarui Status ke Server...');
       google.script.run
         .withSuccessHandler((res) => {
            setJamaahData(updatedData);
            setSelectedIds([]);
            setShowBulkModal(false);
            setBulkDetails({ diagnosa: '', lokasi: '', linkSertifikat: '', certificateFile: null });
            Swal.fire('Berhasil!', res?.message || 'Update status berhasil.', 'success');
         })
         .withFailureHandler((err) => {
            Swal.fire('Error', "Koneksi GAS: " + err, 'error');
         })
         .saveBulkStatusServer(updatedItems);
    } else {
      showLoadingAlert('Memperbarui Status...');
      setTimeout(() => {
        setJamaahData(updatedData);
        setSelectedIds([]);
        setShowBulkModal(false);
        setBulkDetails({ diagnosa: '', lokasi: '', linkSertifikat: '', certificateFile: null });
        Swal.fire('Berhasil!', 'Status berhasil diperbarui secara massal (Lokal Demo).', 'success');
      }, 600);
    }
  };

  const toggleSelectAll = () => {
    if (selectedIds.length === filteredJamaah.length) setSelectedIds([]);
    else setSelectedIds(filteredJamaah.map(j => j.id));
  };

  const toggleSelect = (id) => {
    if (selectedIds.includes(id)) setSelectedIds(selectedIds.filter(i => i !== id));
    else setSelectedIds([...selectedIds, id]);
  };

  const handleBulkDelete = () => {
    if (selectedIds.length === 0) return;
    Swal.fire({
      title: `Hapus ${selectedIds.length} data jemaah?`,
      text: 'Data yang dihapus tidak dapat dikembalikan.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Ya, Hapus',
      cancelButtonText: 'Batal'
    }).then((res) => {
      if (!res.isConfirmed) return;
      const executeLocalDelete = () => {
        const next = jamaahData.filter(j => !selectedIds.includes(j.id));
        setJamaahData(next);
        setSelectedIds([]);
        setPresensiSelected(prev => prev.filter(id => !selectedIds.includes(id)));
        Swal.fire('Terhapus', 'Data jemaah berhasil dihapus.', 'success');
      };

      if (typeof google !== 'undefined' && google.script) {
        showLoadingAlert('Menghapus data...');
        google.script.run
          .withSuccessHandler((result) => {
            Swal.close();
            if (result?.success) executeLocalDelete();
            else Swal.fire('Gagal', result?.message || 'Gagal hapus data.', 'error');
          })
          .withFailureHandler((err) => Swal.fire('Error', err.toString(), 'error'))
          .deleteJamaahServer(selectedIds);
      } else {
        executeLocalDelete();
      }
    });
  };

  // --- LOGIKA PRESENSI ---
  const handlePresensiSelectAll = () => {
    const currentIds = filteredPresensiJamaah.map(j => j.id);
    const allSelected = currentIds.every(id => presensiSelected.includes(id));
    if (allSelected) setPresensiSelected(presensiSelected.filter(id => !currentIds.includes(id)));
    else setPresensiSelected(Array.from(new Set([...presensiSelected, ...currentIds])));
  };

  const handlePresensiSelect = (id) => {
    if (presensiSelected.includes(id)) setPresensiSelected(presensiSelected.filter(i => i !== id));
    else setPresensiSelected([...presensiSelected, id]);
  };

  const openPjModal = () => {
    if (!namaKegiatan) return Swal.fire('Perhatian', 'Ketik/pilih nama kegiatan terlebih dahulu!', 'warning');
    
    const dataBaru = jamaahData.filter(j => presensiSelected.includes(j.id));
    if (dataBaru.length === 0) return Swal.fire('Perhatian', 'Tidak ada jemaah yang dipilih untuk presensi.', 'info');
    
    setShowPjModal(true);
  };

  const handleSimpanPresensi = () => {
    let finalPjName = '';
    let finalPjHp = '';

    if (isNewPj) {
      if (!newPjName) return Swal.fire('Perhatian', 'Nama PJ Baru wajib diisi!', 'warning');
      finalPjName = newPjName;
      finalPjHp = newPjHp;
      
      const newPjObj = { id: 'PJ-' + Date.now(), nama: newPjName, noHp: newPjHp };
      setPjList([...pjList, newPjObj]);
      
      if (typeof google !== 'undefined' && google.script) {
         google.script.run.saveNewPjServer(newPjObj);
      }
    } else {
      if (!selectedPjId) return Swal.fire('Perhatian', 'Silakan pilih PJ dari dropdown!', 'warning');
      const pj = pjList.find(p => p.id === selectedPjId);
      finalPjName = pj.nama;
      finalPjHp = pj.noHp;
    }

    const dataBaru = jamaahData
      .filter(j => presensiSelected.includes(j.id))
      .map(j => ({
        id: j.id,
        tanggal: tglKegiatan,
        paspor: j.paspor || '-',
        nama: j.nama,
        gender: j.gender || '-',
        umur: j.umur || '-',
        provinsi: 'KALIMANTAN BARAT',
        asal: j.asal,
        statusKehadiran: 'IKUT',
        kegiatan: namaKegiatan,
        pj: finalPjName,
        noHpPj: finalPjHp
      }));

    setShowPjModal(false);
    setIsNewPj(false);
    setNewPjName('');
    setNewPjHp('');

    if (typeof google !== 'undefined' && google.script) {
      showLoadingAlert('Menyimpan Data Presensi...');
      google.script.run
        .withSuccessHandler((res) => {
          if (res?.success) {
             setPresensiData([...presensiData, ...dataBaru]);
             Swal.fire('Berhasil!', res?.message || 'Presensi berhasil disimpan.', 'success');
          } else {
             Swal.fire('Gagal!', res?.message || 'Respons server kosong / tidak valid.', 'error');
          }
        })
        .withFailureHandler((err) => {
          Swal.fire('Error', "Koneksi GAS: " + err, 'error');
        })
        .savePresensiServer(dataBaru);
    } else {
      showLoadingAlert('Menyimpan Presensi...');
      setTimeout(() => {
        setPresensiData([...presensiData, ...dataBaru]);
        Swal.fire('Tersimpan!', `Presensi ${dataBaru.length} Jemaah berhasil dicatat (Lokal).`, 'success');
      }, 600);
    }
  };

  // --- UTILS ---
  const copyToClipboard = (elemId) => {
    const text = document.getElementById(elemId).innerText;
    const textArea = document.createElement("textarea");
    textArea.value = text;
    document.body.appendChild(textArea);
    textArea.select();
    document.execCommand('copy');
    document.body.removeChild(textArea);
    Swal.fire({ icon: 'success', title: 'Tersalin!', text: 'Format Laporan WA berhasil disalin ke clipboard.', timer: 2000, showConfirmButton: false });
  };

  const handlePrintPDF = (mode) => {
    if (mode === 'presensi' && !presensiFilterTanggal) {
      Swal.fire('Perhatian', 'Pilih filter tanggal terlebih dahulu agar laporan izin kegiatan terunduh per-hari.', 'warning');
      return;
    }
    setPrintMode(mode);
    setTimeout(() => {
      window.print();
    }, 100);
  };

  const handleSaveEditJamaah = () => {
    if (!editJamaahDraft?.id) return;
    const applyLocal = () => {
      const next = jamaahData.map(j => j.id === editJamaahDraft.id ? { ...j, ...editJamaahDraft } : j);
      setJamaahData(next);
      setSelectedJamaah(editJamaahDraft);
      setIsEditingJamaah(false);
      Swal.fire('Berhasil', 'Data jemaah diperbarui.', 'success');
    };

    if (typeof google !== 'undefined' && google.script) {
      showLoadingAlert('Menyimpan edit data...');
      google.script.run
        .withSuccessHandler((res) => {
          Swal.close();
          if (res?.success) applyLocal();
          else Swal.fire('Gagal', res?.message || 'Gagal simpan edit.', 'error');
        })
        .withFailureHandler((err) => Swal.fire('Error', err.toString(), 'error'))
        .updateJamaahServer(editJamaahDraft);
    } else {
      applyLocal();
    }
  };

  // --- RENDER LOGIN ---
  if (!isLoggedIn) {
    const sourcePreviewData = jamaahData.length > 0 ? jamaahData : (typeof google === 'undefined' ? initialJamaah : []);
    const previewData = sourcePreviewData.filter(j => (loginPreviewKab === 'SEMUA' || j.asal === loginPreviewKab));
    const pStats = {
      total: previewData.length,
      sehat: previewData.filter(j => j.status === 'SEHAT').length,
      sakit: previewData.filter(j => j.status === 'SAKIT').length,
      meninggal: previewData.filter(j => j.status === 'MENINGGAL').length,
    };
    return (
      <div className="min-h-screen bg-gradient-to-br from-green-50 to-emerald-100 flex items-center justify-center p-4 relative overflow-hidden">
        <div className="absolute top-[-10%] left-[-10%] w-96 h-96 bg-green-200 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-pulse"></div>
        <div className="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-emerald-200 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-pulse" style={{animationDelay: '2s'}}></div>

        {!showLoginForm ? (
          <div className="bg-white/90 backdrop-blur-xl rounded-3xl shadow-2xl w-full max-w-4xl p-8 z-10 border border-white/50 space-y-6">
            <div className="text-center">
