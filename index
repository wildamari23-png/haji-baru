          </div>
        )}

        {activeTab === 'pengaturan' && (
          <div className="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 max-w-2xl">
            <h3 className="text-xl font-extrabold mb-4">Pengaturan Branding Admin</h3>
            <div className="space-y-4">
              <input className="w-full border rounded-xl p-3" placeholder="Nama aplikasi" value={appConfig.appName} onChange={(e) => setAppConfig({...appConfig, appName: e.target.value})} />
              <input className="w-full border rounded-xl p-3" placeholder="Nama lengkap admin" value={appConfig.fullName} onChange={(e) => setAppConfig({...appConfig, fullName: e.target.value})} />
              <input className="w-full border rounded-xl p-3" placeholder="Username admin" value={appConfig.username} onChange={(e) => setAppConfig({...appConfig, username: e.target.value})} />
              <input type="password" className="w-full border rounded-xl p-3" placeholder="Password admin" value={appConfig.password} onChange={(e) => setAppConfig({...appConfig, password: e.target.value})} />
              <input className="w-full border rounded-xl p-3" placeholder="Nama Penandatangan PDF" value={appConfig.signatoryName} onChange={(e) => setAppConfig({...appConfig, signatoryName: e.target.value})} />
              <input className="w-full border rounded-xl p-3" placeholder="URL Logo Header" value={appConfig.headerLogo} onChange={(e) => setAppConfig({...appConfig, headerLogo: e.target.value})} />
              <input className="w-full border rounded-xl p-3" placeholder="URL Logo Login" value={appConfig.loginLogo} onChange={(e) => setAppConfig({...appConfig, loginLogo: e.target.value})} />
              <input className="w-full border rounded-xl p-3" placeholder="URL Foto Profil Admin" value={appConfig.adminPhoto} onChange={(e) => setAppConfig({...appConfig, adminPhoto: e.target.value})} />
              {appConfig.adminPhoto && <img src={appConfig.adminPhoto} className="w-32 h-32 rounded-2xl object-cover border" />}
              <button onClick={() => {
                localStorage.setItem('sihaji_config', JSON.stringify(appConfig));
                if (typeof google !== 'undefined' && google.script) google.script.run.saveAppSettingsServer(appConfig);
                modernAlert('success', 'Pengaturan tersimpan', 'Branding aplikasi berhasil diperbarui.');
              }} className="bg-gray-900 text-white px-5 py-3 rounded-xl font-bold">
                Simpan Pengaturan
              </button>
              <button onClick={() => {
                if (typeof google !== 'undefined' && google.script) {
                  showLoadingAlert('Meminta akses Google Drive...');
                  google.script.run
                    .withSuccessHandler((res) => {
                      Swal.close();
                      Swal.fire(res?.success ? 'Sukses' : 'Perhatian', res?.message || 'Tidak ada respons server.', res?.success ? 'success' : 'warning');
                    })
                    .withFailureHandler((err) => Swal.fire('Error', err.toString(), 'error'))
                    .requestDriveAccessServer();
                } else {
                  Swal.fire('Info', 'Fitur ini hanya aktif saat berjalan di Google Apps Script.', 'info');
                }
              }} className="bg-blue-600 text-white px-5 py-3 rounded-xl font-bold">
                Trigger Akses Google Drive
              </button>
            </div>
          </div>
        )}

      </main>

      {selectedJamaah && (
        <div className="fixed inset-0 z-[120] flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
          <div className="bg-white w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden">
            <div className="bg-gradient-to-r from-gray-900 to-gray-700 text-white p-5 flex justify-between">
              <h3 className="font-extrabold">Profil Jemaah Lengkap</h3>
              <button onClick={() => setSelectedJamaah(null)}><i className="fa-solid fa-xmark"></i></button>
            </div>
            <div className="p-6 space-y-4 text-sm">
              <div className="flex justify-end gap-2">
                {!isEditingJamaah ? (
                  <button onClick={() => { setEditJamaahDraft(selectedJamaah); setIsEditingJamaah(true); }} className="bg-amber-500 text-white px-3 py-2 rounded-lg text-xs font-bold">
                    <i className="fa-solid fa-pen mr-1"></i> Edit Data
                  </button>
                ) : (
                  <>
                    <button onClick={() => setIsEditingJamaah(false)} className="bg-gray-200 px-3 py-2 rounded-lg text-xs font-bold">Batal</button>
                    <button onClick={handleSaveEditJamaah} className="bg-green-600 text-white px-3 py-2 rounded-lg text-xs font-bold">Simpan</button>
                  </>
                )}
              </div>

              {!isEditingJamaah ? (
                <div className="grid grid-cols-2 gap-3">
                  <InfoRow label="ID" value={selectedJamaah.id} />
                  <InfoRow label="Paspor" value={selectedJamaah.paspor} />
                  <InfoRow label="Nama" value={selectedJamaah.nama} />
                  <InfoRow label="Gender / Umur" value={`${selectedJamaah.gender} / ${selectedJamaah.umur}`} />
                  <InfoRow label="Kab/Kota" value={selectedJamaah.asal} />
                  <InfoRow label="Status Terkini" value={selectedJamaah.status} />
                </div>
              ) : (
                <div className="grid grid-cols-2 gap-3">
                  <InfoRow label="ID" value={editJamaahDraft?.id} />
                  <input className="border rounded-xl p-3" value={editJamaahDraft?.paspor || ''} onChange={(e) => setEditJamaahDraft({ ...editJamaahDraft, paspor: e.target.value })} placeholder="Paspor" />
                  <input className="border rounded-xl p-3 col-span-2" value={editJamaahDraft?.nama || ''} onChange={(e) => setEditJamaahDraft({ ...editJamaahDraft, nama: e.target.value })} placeholder="Nama" />
                  <select className="border rounded-xl p-3" value={editJamaahDraft?.gender || 'Laki-laki'} onChange={(e) => setEditJamaahDraft({ ...editJamaahDraft, gender: e.target.value })}><option>Laki-laki</option><option>Perempuan</option></select>
                  <input type="number" className="border rounded-xl p-3" value={editJamaahDraft?.umur || ''} onChange={(e) => setEditJamaahDraft({ ...editJamaahDraft, umur: e.target.value })} placeholder="Umur" />
                  <select className="border rounded-xl p-3 col-span-2" value={editJamaahDraft?.asal || lokasiAsalList[0]} onChange={(e) => setEditJamaahDraft({ ...editJamaahDraft, asal: e.target.value })}>{lokasiAsalList.map(k => <option key={k} value={k}>{k}</option>)}</select>
                </div>
              )}
              <div>
                <h4 className="font-bold mb-2">Riwayat Status</h4>
                <div className="space-y-2 max-h-40 overflow-y-auto">
                  {(selectedJamaah.statusHistory || [{ status: selectedJamaah.status, catatan: selectedJamaah.diagnosa || selectedJamaah.lokasiPemakaman || '-', waktu: selectedJamaah.updatedAt || '-' }]).map((h, i) => (
                    <div key={i} className="border rounded-xl p-3 bg-gray-50">
                      <div className="font-bold">{h.status}</div>
                      <div className="text-xs text-gray-500">{h.catatan || '-'}</div>
                      <div className="text-[11px] text-gray-400">{h.waktu}</div>
                    </div>
                  ))}
                </div>
              </div>
              {selectedJamaah.status === 'MENINGGAL' && selectedJamaah.linkSertifikat && (
                <div className="flex gap-2">
                  <a href={selectedJamaah.linkSertifikat} target="_blank" className="bg-blue-600 text-white px-4 py-2 rounded-xl text-xs font-bold">Lihat Sertifikat</a>
                  <a href={selectedJamaah.linkSertifikat} download className="bg-gray-900 text-white px-4 py-2 rounded-xl text-xs font-bold">Download Sertifikat</a>
                </div>
              )}
            </div>
          </div>
        </div>
      )}

      {/* --- ADD JAMAAH MODAL --- */}
      {showAddModal && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm print:hidden p-4">
          <div className="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all animate-fade-in border border-white/20">
            <div className="bg-gray-900 p-5 flex justify-between items-center text-white">
              <h3 className="font-extrabold text-lg flex items-center gap-2"><i className="fa-solid fa-user-plus"></i> Tambah Jemaah Baru</h3>
              <button onClick={() => setShowAddModal(false)} className="hover:bg-gray-800 p-2 rounded-full transition-colors"><i className="fa-solid fa-xmark"></i></button>
            </div>
            <form onSubmit={handleAddJamaah} className="p-6 space-y-4 max-h-[80vh] overflow-y-auto custom-scrollbar">
              <div className="grid grid-cols-2 gap-4">
                 <div>
                    <label className="block text-xs font-bold text-gray-500 mb-1">ID (Otomatis/Manual)</label>
                    <input type="text" required className="w-full p-3 border rounded-xl bg-gray-50 outline-none focus:ring-2 focus:ring-gray-900" placeholder="HJ-..." value={newJamaah.id} onChange={e=>setNewJamaah({...newJamaah, id: e.target.value})} />
                 </div>
                 <div>
                    <label className="block text-xs font-bold text-gray-500 mb-1">No Paspor</label>
                    <input type="text" className="w-full p-3 border rounded-xl bg-gray-50 outline-none focus:ring-2 focus:ring-gray-900" placeholder="Paspor" value={newJamaah.paspor} onChange={e=>setNewJamaah({...newJamaah, paspor: e.target.value})} />
                 </div>
              </div>
              <div>
                <label className="block text-xs font-bold text-gray-500 mb-1">Nama Lengkap</label>
                <input type="text" required className="w-full p-3 border rounded-xl bg-gray-50 outline-none focus:ring-2 focus:ring-gray-900" placeholder="Nama Lengkap Jemaah" value={newJamaah.nama} onChange={e=>setNewJamaah({...newJamaah, nama: e.target.value})} />
              </div>
              <div className="grid grid-cols-2 gap-4">
                 <div>
                    <label className="block text-xs font-bold text-gray-500 mb-1">Umur</label>
                    <input type="number" required className="w-full p-3 border rounded-xl bg-gray-50 outline-none focus:ring-2 focus:ring-gray-900" placeholder="Contoh: 60" value={newJamaah.umur} onChange={e=>setNewJamaah({...newJamaah, umur: e.target.value})} />
                 </div>
                 <div>
                    <label className="block text-xs font-bold text-gray-500 mb-1">Gender</label>
                    <select className="w-full p-3 border rounded-xl bg-gray-50 outline-none focus:ring-2 focus:ring-gray-900" value={newJamaah.gender} onChange={e=>setNewJamaah({...newJamaah, gender: e.target.value})}>
                      <option>Laki-laki</option>
                      <option>Perempuan</option>
                    </select>
                 </div>
              </div>
              <div>
                <label className="block text-xs font-bold text-gray-500 mb-1">Asal Kabupaten/Kota</label>
                <select className="w-full p-3 border rounded-xl bg-gray-50 outline-none focus:ring-2 focus:ring-gray-900" value={newJamaah.asal} onChange={e=>setNewJamaah({...newJamaah, asal: e.target.value})}>
                  {lokasiAsalList.map((k,i) => <option key={i} value={k}>{k}</option>)}
                </select>
              </div>
              <div className="pt-4 flex gap-3">
                <button type="button" onClick={() => setShowAddModal(false)} className="flex-1 px-4 py-3 bg-gray-100 text-gray-700 rounded-xl font-bold hover:bg-gray-200">Batal</button>
                <button type="submit" className="flex-[2] px-4 py-3 bg-gray-900 text-white rounded-xl font-bold hover:bg-black shadow-xl">Simpan Data</button>
              </div>
            </form>
          </div>
        </div>
      )}

      {/* --- BULK UPDATE MODAL --- */}
      {showBulkModal && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm print:hidden p-4">
          <div className="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all animate-fade-in border border-white/20">
            <div className="bg-gradient-to-r from-orange-500 to-amber-500 p-5 flex justify-between items-center text-white">
              <h3 className="font-extrabold text-lg flex items-center gap-2"><i className="fa-solid fa-pen-to-square"></i> Update Massal ({selectedIds.length} Data)</h3>
              <button onClick={() => setShowBulkModal(false)} className="hover:bg-black/20 p-2 rounded-full transition-colors"><i className="fa-solid fa-xmark"></i></button>
            </div>
            <div className="p-6 space-y-5">
              <div>
                <label className="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Pilih Status Baru</label>
                <div className="relative">
                  <select 
                    className="w-full pl-4 pr-10 py-3 border border-gray-200 bg-gray-50 rounded-xl focus:ring-2 focus:ring-orange-500 focus:bg-white outline-none font-bold text-gray-700 appearance-none"
                    value={bulkStatus}
                    onChange={(e) => setBulkStatus(e.target.value)}
                  >
                    <option value="SEHAT">✓ SEHAT / AKTIF</option>
                    <option value="SAKIT">⚠ SAKIT / DIRAWAT</option>
                    <option value="MENINGGAL">✝ WAFAT / MENINGGAL</option>
                  </select>
                  <i className="fa-solid fa-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                </div>
              </div>

              {bulkStatus === 'SAKIT' && (
                <div className="space-y-4 animate-fade-in bg-orange-50 p-4 rounded-2xl border border-orange-100">
                  <div>
                    <label className="block text-xs font-bold text-gray-600 mb-1">Keterangan / Diagnosa</label>
                    <input type="text" className="w-full p-3 border-none bg-white rounded-xl shadow-sm outline-none focus:ring-2 focus:ring-orange-400" placeholder="Misal: ISPA / Kelelahan" value={bulkDetails.diagnosa} onChange={e => setBulkDetails({...bulkDetails, diagnosa: e.target.value})} />
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-gray-600 mb-1">Lokasi Perawatan</label>
                    <input type="text" className="w-full p-3 border-none bg-white rounded-xl shadow-sm outline-none focus:ring-2 focus:ring-orange-400" placeholder="Misal: RS King Faisal, Makkah" value={bulkDetails.lokasi} onChange={e => setBulkDetails({...bulkDetails, lokasi: e.target.value})} />
                  </div>
                </div>
              )}

              {bulkStatus === 'MENINGGAL' && (
                <div className="space-y-4 animate-fade-in bg-red-50 p-4 rounded-2xl border border-red-100">
                  <div>
                    <label className="block text-xs font-bold text-gray-600 mb-1">Lokasi Pemakaman</label>
                    <input type="text" className="w-full p-3 border-none bg-white rounded-xl shadow-sm outline-none focus:ring-2 focus:ring-red-400 mb-3" placeholder="Misal: Sharaya, Makkah" value={bulkDetails.lokasi} onChange={e => setBulkDetails({...bulkDetails, lokasi: e.target.value})} />
                  </div>
                  <div className="pt-2 border-t border-red-200">
                    <label className="block text-xs font-bold text-gray-600 mb-2">Upload Sertifikat Kematian langsung dari form</label>
                    <input type="file" accept=".pdf,image/*" className="w-full p-3 border-none bg-white rounded-xl shadow-sm outline-none focus:ring-2 focus:ring-red-400 text-sm mb-2" onChange={e => setBulkDetails({...bulkDetails, certificateFile: e.target.files?.[0] || null})} />
                    {bulkDetails.linkSertifikat && (
                      <a href={bulkDetails.linkSertifikat} target="_blank" className="text-xs text-blue-600 font-semibold hover:underline">File tersimpan otomatis. Klik untuk lihat sertifikat.</a>
                    )}
                  </div>
                </div>
              )}

              <div className="pt-4 flex gap-3">
                <button onClick={() => setShowBulkModal(false)} className="flex-1 px-4 py-3.5 bg-gray-100 text-gray-700 rounded-xl font-bold hover:bg-gray-200 transition-colors">Batal</button>
                <button onClick={handleBulkUpdate} className="flex-[2] px-4 py-3.5 bg-gray-900 text-white rounded-xl font-bold hover:bg-black shadow-xl shadow-gray-900/20 transition-all flex justify-center items-center gap-2">
                  <i className="fa-solid fa-check-double"></i> Simpan Update
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* --- MODAL PILIH / TAMBAH PJ --- */}
      {showPjModal && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm print:hidden p-4">
          <div className="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden transform transition-all animate-fade-in border border-white/20">
            <div className="bg-green-600 p-5 flex justify-between items-center text-white">
              <h3 className="font-extrabold text-lg flex items-center gap-2"><i className="fa-solid fa-user-shield"></i> Pilih Penanggung Jawab (PJ)</h3>
              <button onClick={() => setShowPjModal(false)} className="hover:bg-green-700 p-2 rounded-full transition-colors"><i className="fa-solid fa-xmark"></i></button>
            </div>
            
            <div className="p-6 space-y-5">
              {!isNewPj ? (
                <div className="animate-fade-in">
                  <label className="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Pilih Nama PJ</label>
                  <div className="relative mb-4">
                    <select 
                      className="w-full pl-4 pr-10 py-3 border border-gray-200 bg-gray-50 rounded-xl focus:ring-2 focus:ring-green-500 outline-none font-bold text-gray-700 appearance-none"
                      value={selectedPjId}
                      onChange={(e) => setSelectedPjId(e.target.value)}
                    >
                      <option value="" disabled>-- Pilih PJ dari Daftar --</option>
                      {pjList.map(p => (
                        <option key={p.id} value={p.id}>{p.nama} ({p.noHp})</option>
                      ))}
                    </select>
                    <i className="fa-solid fa-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                  </div>
                  
                  <div className="text-center">
                    <span className="text-xs text-gray-500">PJ tidak ada di daftar?</span>
                    <button type="button" onClick={() => setIsNewPj(true)} className="ml-2 text-green-600 font-bold hover:underline text-sm">
                       + Tambah PJ Baru
                    </button>
                  </div>
                </div>
              ) : (
                <div className="space-y-4 animate-fade-in bg-green-50 p-4 rounded-2xl border border-green-100">
                  <h4 className="font-bold text-green-800 border-b border-green-200 pb-2 mb-3">Input Data PJ Baru</h4>
                  <div>
                    <label className="block text-xs font-bold text-gray-600 mb-1">Nama Lengkap PJ</label>
                    <input type="text" className="w-full p-3 border-none bg-white rounded-xl shadow-sm outline-none focus:ring-2 focus:ring-green-400" placeholder="Misal: Budi Santoso" value={newPjName} onChange={e => setNewPjName(e.target.value)} />
                  </div>
                  <div>
                    <label className="block text-xs font-bold text-gray-600 mb-1">Nomor Handphone (Opsional)</label>
                    <input type="text" className="w-full p-3 border-none bg-white rounded-xl shadow-sm outline-none focus:ring-2 focus:ring-green-400" placeholder="Misal: 0812..." value={newPjHp} onChange={e => setNewPjHp(e.target.value)} />
                  </div>
                  <div className="text-center pt-2">
                    <button type="button" onClick={() => setIsNewPj(false)} className="text-gray-500 hover:text-gray-700 text-xs font-bold underline">
                       Batal Tambah Baru, Pilih dari Daftar
                    </button>
                  </div>
                </div>
              )}

              <div className="pt-4 flex gap-3">
                <button onClick={() => setShowPjModal(false)} className="flex-1 px-4 py-3.5 bg-gray-100 text-gray-700 rounded-xl font-bold hover:bg-gray-200 transition-colors">Batal</button>
                <button onClick={handleSimpanPresensi} className="flex-[2] px-4 py-3.5 bg-green-600 text-white rounded-xl font-bold hover:bg-green-700 shadow-xl shadow-green-600/20 transition-all flex justify-center items-center gap-2">
                  <i className="fa-solid fa-floppy-disk"></i> Simpan & Lanjutkan
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

// --- SUB COMPONENTS ---
function NavBtn({ icon, label, active, onClick }) {
  return (
    <button 
      onClick={onClick}
      className={`flex md:flex-row flex-col items-center gap-1.5 md:gap-4 p-2.5 md:px-5 md:py-3.5 w-full rounded-2xl transition-all duration-300 group ${active ? 'bg-gradient-to-r from-green-500 to-emerald-600 text-white shadow-lg shadow-green-500/20 font-bold' : 'text-gray-500 hover:bg-gray-800 hover:text-gray-200'}`}
    >
      <i className={`fa-solid ${icon} text-lg md:text-xl ${active ? 'animate-bounce' : 'group-hover:scale-110 transition-transform'}`}></i>
      <span className="text-[10px] md:text-sm tracking-wide">{label}</span>
    </button>
  );
}

function StatCard({ title, value, icon, color, bg }) {
  return (
    <div className="p-5 md:p-6 rounded-3xl bg-white shadow-sm border border-gray-100 relative overflow-hidden group hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
      <div className={`absolute -right-6 -top-6 w-32 h-32 ${bg} rounded-full opacity-50 group-hover:scale-[1.8] transition-transform duration-700 ease-out`}></div>
      <div className="relative z-10 flex flex-col h-full justify-between">
        <div className="flex justify-between items-start mb-4">
          <p className="text-xs md:text-sm font-bold text-gray-400 uppercase tracking-wider">{title}</p>
          <div className={`w-10 h-10 rounded-2xl ${bg} flex items-center justify-center`}>
            <i className={`fa-solid ${icon} ${color} text-lg`}></i>
          </div>
        </div>
        <h3 className={`text-4xl font-black text-gray-800 tracking-tight`}>{value}</h3>
      </div>
    </div>
  );
}

function StatusBadge({ status }) {
  const styles = {
    SEHAT: 'bg-green-100 text-green-700 border-green-200',
    SAKIT: 'bg-orange-100 text-orange-700 border-orange-200',
    MENINGGAL: 'bg-red-100 text-red-700 border-red-200',
  };
  const icons = {
    SEHAT: 'fa-heart-circle-check',
    SAKIT: 'fa-bed-pulse',
    MENINGGAL: 'fa-book-skull'
  };
  
  return (
    <div className={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-wider border ${styles[status] || 'bg-gray-100 text-gray-700'}`}>
      <i className={`fa-solid ${icons[status] || 'fa-circle-info'}`}></i> {status}
    </div>
  );
}

function InfoRow({ label, value }) {
  return (
    <div className="border rounded-xl p-3 bg-gray-50">
      <div className="text-[10px] uppercase text-gray-400 font-bold">{label}</div>
      <div className="font-bold text-gray-800">{value || '-'}</div>
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<App />);
</script>
</body>
</html>
